	params:
		ident_sim = lambda wildcards : "_".join(wildcards)
	resources:
		mem_mb = 4000,
		runtime = 60
	shell:
		"""
		export PYTENSOR_FLAGS="compiledir=${{TMPDIR:-/tmp}}/cross-reactivity/pytensor_sim_{params.ident_sim}/{jobid}"
