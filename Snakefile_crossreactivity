import pandas as pd
import numpy as np
import copepodTCR as cpp
import codepub as cdp
import math

method = ['copepodTCR', 'basic']
len_lst = [100, 500, 1000, 1500]
wanted_neg_share = [0.6]
overlap = [4, 6]
ep_length = [8, 14]
pep_length = [14]
mu_off_strong = [5, 15]
mu_off_weak = [5, 15]
sigma_off = [3]
sigma_p_r = [3]
sigma_n_r = [3]
mu_n = [5, 15]
sigma_n = [3]
r = [1, 2]

